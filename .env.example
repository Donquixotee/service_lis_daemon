# ============================================================
# LIS Daemon — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# Odoo connection
ODOO_URL=http://localhost:8069
ODOO_DB=alwahab_prod
ODOO_USER_LOGIN=lis.daemon@alwahab.dz

# Authentication — use API key (recommended) or password
# Generate API key: Odoo > Settings > Users > LIS Daemon Bot > Preferences > Account Security > New API Key
ODOO_API_KEY=your-api-key-here
# ODOO_PASSWORD=  # fallback if API keys not enabled

# Daemon config
LIS_CONFIG_PATH=config/daemon.yml
LIS_LOG_LEVEL=INFO

# Docker network
# Dev (Odoo runs locally, not in Docker): leave these unset — daemon runs as plain Python, no Docker
# Test/Prod (Odoo runs in Docker): set these to join Odoo's network
#   DOCKER_NETWORK_EXTERNAL=true
#   DOCKER_NETWORK=alwahab_network
# If using Docker but with a local Odoo: set DOCKER_NETWORK_EXTERNAL=false (creates isolated bridge)
DOCKER_NETWORK_EXTERNAL=false
DOCKER_NETWORK=lis_network
