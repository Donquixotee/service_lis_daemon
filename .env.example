# ============================================================
# LIS Daemon — Environment Variables (Example)
# Copy this file to .env and configure for your environment.
# ============================================================

# ------------------------------------------------------------
# Odoo connection
# ------------------------------------------------------------
ODOO_URL=http://localhost:8069
ODOO_DB=your_database_name
ODOO_USER_LOGIN=your_user_login

# ------------------------------------------------------------
# Authentication
# Prefer API keys over passwords (recommended)
# ------------------------------------------------------------

# ODOO_API_KEY=your_api_key_here
# ODOO_PASSWORD=your_password_here  # fallback if API keys are not used

# ------------------------------------------------------------
# LIS Daemon configuration
# ------------------------------------------------------------
LIS_CONFIG_PATH=config/daemon.yml
LIS_LOG_LEVEL=INFO

# ------------------------------------------------------------
# Docker networking (optional)
# ------------------------------------------------------------
# This section controls how the daemon connects to Odoo when Docker is involved.

# DEV MODE (no Docker):
# - Odoo runs directly on your machine (not inside Docker)
# - Leave these variables empty or unset
# - The daemon connects via normal localhost (e.g. http://localhost:8069)

# DOCKER MODE (Odoo runs in Docker):
# - Use this when Odoo is running inside a Docker container or Docker Compose stack
# - Enables the daemon to join the same Docker network as Odoo

# Set to "true" if you want to connect to an existing external Docker network
# (e.g. shared network created by another compose stack)
# DOCKER_NETWORK_EXTERNAL=true

# Name of the Docker network to join (must match your Docker/Compose network name)
# Example: my_project_network
# DOCKER_NETWORK=your_docker_network_name

# ISOLATED MODE (recommended for local testing with Docker):
# - If Odoo is in Docker but you want a private isolated network for the daemon
# - Set external to false so the daemon creates/uses its own bridge network
DOCKER_NETWORK_EXTERNAL=false
DOCKER_NETWORK=your_local_docker_network_name